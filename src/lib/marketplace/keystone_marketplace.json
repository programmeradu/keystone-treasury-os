{
    "address": "F8kN2gs4kqHtz2bkJZLbtNm6j8e7EUSarYDQcXff8iQY",
    "metadata": {
        "name": "keystone_marketplace",
        "version": "1.0.0",
        "spec": "0.1.0",
        "description": "Keystone Marketplace — On-chain app registry with 80/20 revenue split and License NFT minting."
    },
    "instructions": [
        {
            "name": "initializeApp",
            "docs": ["Initialize an app listing for sale."],
            "accounts": [
                { "name": "appRegistry", "writable": true, "pda": { "seeds": [{ "kind": "const", "value": "app_registry" }, { "kind": "arg", "path": "appId" }] } },
                { "name": "developer", "writable": true, "signer": true },
                { "name": "systemProgram", "address": "11111111111111111111111111111111" }
            ],
            "args": [
                { "name": "appId", "type": { "array": ["u8", 32] } },
                { "name": "priceUsdc", "type": "u64" },
                { "name": "developerFeeBps", "type": "u16" },
                { "name": "ipfsCid", "type": { "array": ["u8", 64] } }
            ]
        },
        {
            "name": "purchaseApp",
            "docs": ["Purchase app: split USDC 80/20, mint License NFT to buyer."],
            "accounts": [
                { "name": "appRegistry", "writable": true, "pda": { "seeds": [{ "kind": "const", "value": "app_registry" }, { "kind": "arg", "path": "appId" }] } },
                { "name": "developer" },
                { "name": "buyer", "writable": true, "signer": true },
                { "name": "buyerUsdcAccount", "writable": true },
                { "name": "developerUsdcAccount", "writable": true },
                { "name": "treasuryUsdcAccount", "writable": true },
                { "name": "usdcMint" },
                { "name": "licenseMint", "writable": true },
                { "name": "licenseAuthority", "pda": { "seeds": [{ "kind": "const", "value": "license_authority" }, { "kind": "account", "path": "appRegistry" }] } },
                { "name": "buyerLicenseAccount", "writable": true },
                { "name": "tokenProgram", "address": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA" },
                { "name": "systemProgram", "address": "11111111111111111111111111111111" }
            ],
            "args": [
                { "name": "appId", "type": { "array": ["u8", 32] } }
            ]
        }
    ],
    "accounts": [
        {
            "name": "AppRegistry",
            "type": {
                "kind": "struct",
                "fields": [
                    { "name": "developer", "type": "pubkey" },
                    { "name": "priceUsdc", "type": "u64" },
                    { "name": "developerFeeBps", "type": "u16" },
                    { "name": "ipfsCid", "type": { "array": ["u8", 64] } },
                    { "name": "isListed", "type": "bool" },
                    { "name": "bump", "type": "u8" }
                ]
            }
        }
    ],
    "events": [
        {
            "name": "PurchaseEvent",
            "fields": [
                { "name": "appId", "type": { "array": ["u8", 32] } },
                { "name": "buyer", "type": "pubkey" },
                { "name": "developer", "type": "pubkey" },
                { "name": "price", "type": "u64" },
                { "name": "developerShare", "type": "u64" },
                { "name": "protocolShare", "type": "u64" },
                { "name": "timestamp", "type": "i64" }
            ]
        }
    ],
    "errors": [
        { "code": 6000, "name": "AppNotListed", "msg": "App is not listed for sale" },
        { "code": 6001, "name": "InvalidLicenseAuthority", "msg": "Invalid license authority PDA" }
    ]
}
