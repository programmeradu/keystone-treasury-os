# ---------------------------------------------
# KeyStone: Environment Variables (Example)
# ---------------------------------------------
# Copy this file to .env and fill in the values you need for local dev.
# .env is gitignored. Do NOT commit real secrets.

# --- Core / App ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Solana / Atlas ---
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta
# Public RPC (optional; many endpoints rate-limit):
NEXT_PUBLIC_SOLANA_RPC=
# Preferred Solana infra (server-side)
HELIUS_API_KEY=

# --- Analytics Providers ---
BITQUERY_API_KEY=
# Alternatively, if using bearer token header for Bitquery:
BITQUERY_BEARER=

# Moralis (optional; used by some Solana holders endpoints)
MORALIS_API_KEY=

# --- Swaps / Bridges (optional) ---
# 0x / Matcha
ZERO_EX_API_KEY=
# Rango bridge
RANGO_API_KEY=

# --- EVM RPC (optional) ---
# Used by generic RPC route examples
NOWNODES_API_KEY=
ETH_RPC_URL=

# --- Wallets / Providers (client-safe) ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Coinbase Developer Platform (optional demo integration)
NEXT_PUBLIC_CDP_API_KEY=

# --- Oracle / AI (optional) ---
OPENAI_API_KEY=
GROQ_API_KEY=
NLPCLOUD_API_KEY=
NLPCLOUD_MODEL=chatdolphin
NLPCLOUD_USE_GPU=false
# Puter demo integration
PUTER_BASE_URL=
PUTER_API_KEY=
NEXT_PUBLIC_PUTER_API_KEY=

# --- GitHub Cleanup (Local-only feature) ---
# Enable the /github-cleanup UI and related APIs locally
GITHUB_DELETE_ENABLED=false
# Provide one of the following; classic PAT with appropriate scopes recommended
GITHUB_TOKEN=
GH_TOKEN=
GITHUB_PAT=
# If using classic PAT to delete repositories, include at least: repo, delete_repo
# For fine-grained PATs, grant Administration: Read & write for targeted repos

# --- Database (optional) ---
# Turso (if/when used by DB layer)
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# --- Visual Edits (optional internal tooling) ---
VISUAL_EDITS_ENABLED=false

# --- Dev / Testing toggles ---
MOCK_MODE=false
BASE_URL=http://localhost:3000
SAMPLE_SOL_ADDRESS=

# --- CI Safety / Hooks ---
# Set to true only if you intentionally want to bypass pre-push secret scanning
ALLOW_PUSH_WITH_SECRETS=false

# --- Jupiter Swaps (optional) ---
JUPITER_REFERRAL_ACCOUNT=
JUPITER_APP_ID=
NEXT_PUBLIC_JUPITER_APP_ID=

# --- Paddle Billing (merchant of record) ---
# Server-side API key from Paddle (Dashboard → Developer tools). Never expose client-side.
PADDLE_API_KEY=
# Secret from the Paddle notification destination used for /api/webhooks/paddle
PADDLE_WEBHOOK_SECRET=
# Optional: product id after running npm run paddle:seed-catalog
PADDLE_PRODUCT_ID=
# Catalog price IDs (pri_…) for Mini and Max — filled by paddle:seed-catalog or Dashboard
PADDLE_PRICE_ID_MINI=
PADDLE_PRICE_ID_MAX=
# Set true for sandbox API; false for live (https://api.paddle.com)
PADDLE_USE_SANDBOX=true
# Optional: tax category for catalog seed (saas | standard | …) — must be enabled on your Paddle account
PADDLE_CATALOG_TAX_CATEGORY=saas
PADDLE_CATALOG_TAX_CATEGORY_FALLBACK=standard
# Optional: subscription unit amounts in USD cents (defaults: 4900 / 19900)
# PADDLE_MINI_UNIT_AMOUNT=4900
# PADDLE_MAX_UNIT_AMOUNT=19900
# Optional: trial on both prices (days). Omit for no trial.
# PADDLE_TRIAL_DAYS=14

# --- FastSpring (merchant of record) ---
# Developer Tools → APIs → API Credentials (Basic auth). Password shown only once.
FASTSPRING_API_USERNAME=
FASTSPRING_API_PASSWORD=
# Checkout path from FastSpring (format: store-id/checkout-id, e.g. mystore/main).
# Set in the FastSpring app when you configure Web Checkout; there is no API to create this id.
FASTSPRING_CHECKOUT_PATH=
# Full webhook URL exactly as registered in FastSpring (used by npm run fastspring:set-webhook-hmac)
FASTSPRING_WEBHOOK_URL=
# HMAC SHA256 secret (1–100 chars). After adding the URL in FastSpring, run fastspring:set-webhook-hmac to sync.
FASTSPRING_WEBHOOK_SECRET=
# App verifies inbound webhooks with this secret. https://<your-domain>/api/webhooks/fastspring
# Enable webhook expansion for richer payloads; tier sync still works via API reconciliation.
# Filled after: npm run fastspring:seed-catalog
FASTSPRING_PRODUCT_PATH_MINI=
FASTSPRING_PRODUCT_PATH_MAX=
# Reconcile subscriptions: live | test | all (default live)
# FASTSPRING_SUBSCRIPTION_SCOPE=live
# Use FastSpring test orders / test cards (checkout session live:false)
# FASTSPRING_USE_TEST_ORDERS=false
# Optional: ISO country for pre-created buyer accounts (API account.create)
# FASTSPRING_DEFAULT_ACCOUNT_COUNTRY=US
# Optional overrides for seed script:
# FASTSPRING_MINI_PRODUCT_PATH=keystone-os-mini
# FASTSPRING_MAX_PRODUCT_PATH=keystone-os-max
# FASTSPRING_MINI_USD=49
# FASTSPRING_MAX_USD=199
# FASTSPRING_TRIAL_DAYS=14

# Notes:
# - Atlas can run with degraded functionality without some provider keys.
# - Transactions are always signed client-side; no private keys are stored server-side.
# - For production deployment on Netlify, set these in Site Settings → Environment Variables