{
  "name": "@keystone-os/sdk",
  "version": "0.2.0",
  "description": "SDK for Keystone Studio Mini-Apps — useVault, useTurnkey, useFetch, AppEventBus",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "keystone",
    "web3",
    "treasury",
    "studio",
    "mini-app",
    "solana"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/programmeradu/keystone-treasury-os.git",
    "directory": "packages/sdk"
  }
}
